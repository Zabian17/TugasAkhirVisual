<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.tugas_akhir.CustomerController"
      spacing="0" style="-fx-background-color: #f8f9fa;">

    
    <VBox spacing="20" style="-fx-padding: 24px;">
        <Label text="Customer" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>

        
        <HBox spacing="12" alignment="CENTER_LEFT">
            
            <ComboBox fx:id="cbCategory" 
                      promptText="All"
                      prefWidth="150"
                      styleClass="form-combo"
                      onAction="#handleFilterChange"/>

            
            <ComboBox fx:id="cbStatus" 
                      promptText="All status"
                      prefWidth="150"
                      styleClass="form-combo"
                      onAction="#handleFilterChange"/>

            <Region HBox.hgrow="ALWAYS"/>

            
            <Button text="➕ Add Customer" 
                    styleClass="btn-primary"
                    onAction="#handleAddCustomer"
                    prefWidth="140"/>

            
            <TextField fx:id="tfSearch"
                       promptText="Search name, id, company..."
                       styleClass="form-field"
                       prefWidth="200"
                       onKeyReleased="#handleSearch"/>
        </HBox>
    </VBox>

    
    <ScrollPane fitToWidth="true" style="-fx-background-color: #f8f9fa; -fx-border-color: transparent;">
        <TilePane fx:id="tileCustomers"
                  prefColumns="3"
                  hgap="20"
                  vgap="20"
                  style="-fx-padding: 20px;"
                  prefWidth="1200"/>
    </ScrollPane>

</VBox>
