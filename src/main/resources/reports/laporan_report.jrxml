            <textField>
                <reportElement x="0" y="75" width="782" height="20" uuid="c3d4e5f6-a7b8-9012-cdef-123456789005"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Total Transaksi: " + $P{totalTransaksi} + "  |  Total Masuk: " + $P{totalMasuk} + "  |  Total Keluar: " + $P{totalKeluar} + "  |  Barang Aktif: " + $P{barangAktif}]]></textFieldExpression>
